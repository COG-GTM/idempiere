# Database (defaults match docker-compose)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=o2c
PORT=3001

# Vercel / managed Postgres deployment.
# DATABASE_URL should point at a TLS-enabled managed database (sslmode=require).
DATABASE_URL=

# Arm the seeded regression: multi-currency allocations fail the GL balance check.
ALLOC_BUG=0
# Keep recompute work within serverless limits; the local docker default stays 9000.
RECOMPUTE_SCALE=9000

# Sentry (optional). DSN is never logged.
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod

# Datadog (optional). Local docker uses the agent; Vercel uses HTTP intake.
# NOTE: this account's key is on the EU site — use DD_SITE=datadoghq.eu.
DD_API_KEY=
DD_SITE=datadoghq.eu
DD_AGENT_HOST=localhost

# Alerting is NOT done by this service. Sentry's and Datadog's own Slack
# integrations raise the alert (Sentry alert rule + Datadog monitor → #sam-dd-demo),
# which triggers the Devin automation. The app only emits to Sentry + Datadog.
