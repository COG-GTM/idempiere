# Database (defaults match docker-compose)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=o2c
PORT=3001

# Arm the seeded regression: multi-currency allocations fail the GL balance check.
ALLOC_BUG=0

# Sentry (optional). DSN is never logged.
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod

# Datadog (optional). Agent forwards APM/metrics when DD_API_KEY is set.
DD_API_KEY=
DD_SITE=datadoghq.com
DD_AGENT_HOST=localhost

# Slack alert (optional) — incoming webhook bound to #sam-dd-demo.
SLACK_INCOMING_WEBHOOK_URL=

# Optional: open a Devin triage session via API on a posting failure.
DEVIN_API_KEY=
