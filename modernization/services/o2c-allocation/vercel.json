{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "public/**",
        "src/**",
        "node_modules/@electric-sql/pglite/dist/**"
      ],
      "maxDuration": 60
    }
  }
}
